# =============================================================
# YouTube Transcript Extractor - Environment Variables
# =============================================================
# Copy this file to .env and fill in the values
# Only OXYLABS vars are optional — everything works without them
# =============================================================

# Backend URL (used by frontend server actions)
# Default works with Docker Compose out of the box
BACKEND_URL=http://localhost:5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Database (SQLite - no config needed for Docker)
DATABASE_URL=file:./data/transcripts.db

# --- Optional: Oxylabs Residential Proxy ---
# Improves reliability for high-volume usage
# Sign up at https://oxylabs.io/products/residential-proxy-pool
# OXYLABS_RESIDENTIAL_USERNAME=
# OXYLABS_RESIDENTIAL_PASSWORD=

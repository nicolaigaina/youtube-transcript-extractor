# =============================================================
# YouTube Transcript Extractor - Environment Variables
# =============================================================
# Copy this file to .env and fill in the values
# Only OXYLABS vars are optional — everything works without them
# =============================================================

# Backend URL (used by frontend server actions)
# Default works with Docker Compose out of the box
BACKEND_URL=http://localhost:5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Database (SQLite - no config needed for Docker)
DATABASE_URL=file:./data/transcripts.db

# --- Optional: Oxylabs Residential Proxy ---
# YouTube blocks automated requests from server/cloud IPs.
# Residential proxies route requests through real consumer IPs,
# making them indistinguishable from normal YouTube viewers.
#
# Required if: deploying to cloud, high-volume usage, or getting
# TranscriptsDisabled errors for videos that have captions.
#
# Not needed for: local development or low-volume personal use.
#
# Sign up: https://oxylabs.io/products/residential-proxy-pool
# Choose "Residential Proxy" (NOT datacenter — YouTube blocks those).
# Cost: Pay-per-GB, typically under $1/month for transcript extraction.
#
# OXYLABS_RESIDENTIAL_USERNAME=customer-your_username
# OXYLABS_RESIDENTIAL_PASSWORD=your_password
